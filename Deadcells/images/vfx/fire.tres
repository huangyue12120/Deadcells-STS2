[gd_resource type="ShaderMaterial" load_steps=2 format=3 uid="uid://c3xtyoloskv7g"]

[sub_resource type="Shader" id="Shader_t2iyj"]
code = "shader_type canvas_item;
render_mode blend_mix, unshaded;

uniform sampler2D noise_tex : repeat_enable, filter_linear_mipmap;

uniform vec4 fire_color : source_color = vec4(1.0, 0.32, 0.03, 1.0);
uniform vec4 hot_color  : source_color = vec4(1.0, 0.75, 0.28, 1.0);

uniform float fire_alpha : hint_range(0.0, 1.0) = 0.75;
uniform float noise_scale = 26.0;
uniform vec2 fire_speed = vec2(0.0, 28.0);

uniform float threshold : hint_range(0.0, 1.0) = 0.50;
uniform float softness  : hint_range(0.01, 0.5) = 0.18;
uniform float body_fill : hint_range(0.0, 1.0) = 0.42;
uniform float edge_gain : hint_range(0.0, 4.0) = 0.85;
uniform float fire_base_y = 0.0;   // 怪物“脚底附近”的世界 y
uniform float fire_height = 90.0;  // 火焰往上蔓延多高

varying vec2 world_pos;

void vertex() {
    world_pos = (MODEL_MATRIX * vec4(VERTEX, 0.0, 1.0)).xy;
}

float edge_sample(sampler2D tex, vec2 texel_size, vec2 uv, vec2 dir, float px) {
    float a0 = texture(tex, uv).a;
    float a1 = texture(tex, uv + dir * texel_size * px).a;
    return max(a0 - a1, 0.0);
}

void fragment() {
    vec4 base = texture(TEXTURE, UV);
    COLOR = base;

    if (base.a > 0.001) {
        vec2 n_uv = (world_pos + TIME * fire_speed) / noise_scale;

        float n1 = texture(noise_tex, n_uv).r;
        float n2 = texture(noise_tex, n_uv * 1.83 + vec2(2.17, -TIME * 0.55)).r;
        float n  = clamp(n1 * 0.65 + n2 * 0.35, 0.0, 1.0);

        float edge = 0.0;
        edge += edge_sample(TEXTURE, TEXTURE_PIXEL_SIZE, UV, vec2( 1.0, 0.0), 2.0);
        edge += edge_sample(TEXTURE, TEXTURE_PIXEL_SIZE, UV, vec2(-1.0, 0.0), 2.0);
        edge += edge_sample(TEXTURE, TEXTURE_PIXEL_SIZE, UV, vec2( 0.0, 1.0), 2.0);
        edge += edge_sample(TEXTURE, TEXTURE_PIXEL_SIZE, UV, vec2( 0.0,-1.0), 2.0);
        edge = clamp(edge * edge_gain, 0.0, 1.0);

        // 下强上弱：脚底附近 strongest，往上逐渐衰减
        float up01 = clamp((fire_base_y - world_pos.y) / fire_height, 0.0, 1.0);
        float bottom_mask = 1.0 - up01;
        bottom_mask = pow(bottom_mask, 1.6);

        // 让噪声变成更稀疏的“燃点”，而不是整片花纹
        float flame_core = smoothstep(threshold - softness, threshold + softness, n);
        float flame_cap  = 1.0 - smoothstep(threshold + 0.16, threshold + 0.28, n);
        float flame_band = flame_core * flame_cap;

        float inner_intensity = flame_band * bottom_mask * base.a * body_fill * 1.8;
        inner_intensity = clamp(inner_intensity, 0.0, 1.0);

        float edge_intensity = edge * (0.08 + bottom_mask * 0.28);

        vec3 fire_rgb = mix(fire_color.rgb, hot_color.rgb, clamp(n * 1.1, 0.0, 1.0));

        vec3 result = base.rgb;
        result += fire_rgb * inner_intensity * fire_alpha;
        result += hot_color.rgb * edge_intensity * fire_alpha * 0.22;

        float final_mix = clamp(inner_intensity * 0.95 + edge_intensity * 0.22, 0.0, 1.0);
        result = mix(base.rgb, result, final_mix);

        COLOR = vec4(result, base.a);
    }
}"

[resource]
shader = SubResource("Shader_t2iyj")
shader_parameter/fire_color = Color(0.76887196, 0.14378005, 0, 1)
shader_parameter/hot_color = Color(0.98164004, 0.43258676, 0, 1)
shader_parameter/fire_alpha = 0.75
shader_parameter/noise_scale = 50.0
shader_parameter/fire_speed = Vector2(0, 60)
shader_parameter/threshold = 0.30000001425
shader_parameter/softness = 0.25000001117647996
shader_parameter/body_fill = 0.6000000285
shader_parameter/edge_gain = 0.85
shader_parameter/fire_base_y = 0.0
shader_parameter/fire_height = 90.0
