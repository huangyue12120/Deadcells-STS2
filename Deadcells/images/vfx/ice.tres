shader_parameter/ice_highlight = Color(0.98, 0.995, 1, 1)
shader_parameter/freeze_amount = 0.6000000285
shader_parameter/tint_strength = 0.50000002375
shader_parameter/edge_strength = 1.0000000475
shader_parameter/crystal_strength = 0.400000019
shader_parameter/crystal_scale = 40.00000152
shader_parameter/crystal_line_width = 0.03000000107574
shader_parameter/shimmer_amount = 0.1200000057
